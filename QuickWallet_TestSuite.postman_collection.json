          }
        },
        {
          "name": "T12 - Verify User A balance decreased by 100",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('T12 - Transfer integrity: User A balance decreased by 100', function () {",
