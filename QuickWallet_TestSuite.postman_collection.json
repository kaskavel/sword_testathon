          }
        },
        {
          "name": "Setup - Snapshot balances before transfer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Snapshot - User A balance recorded', function () {",
                  "    const json = pm.response.json();",
                  "    const acct = Array.isArray(json) ? json.find(a => a.id == pm.collectionVariables.get('user_a_account_id')) : json;",
                  "    const balance = parseFloat(acct?.balance ?? acct?.accounts?.[0]?.balance ?? 300);",
                  "    pm.collectionVariables.set('user_a_balance_before_transfer', balance);",
                  "    pm.expect(balance).to.be.a('number');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
